@model WebApplication1.Models.Ingrediente

@{
    ViewData["Title"] = "Excluir Ingrediente";
}

<h1>Excluir Ingrediente</h1>

<h3>Tem certeza que deseja excluir?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Nome)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Nome)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Descricao)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Descricao)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar</a>
    </form>
</div>
