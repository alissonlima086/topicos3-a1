@model WebApplication1.Models.ConfiguracaoDelivery
@{
    ViewData["Title"] = "Editar Configuração de Delivery";
}

<h2 class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined">local_shipping</span> Editar Configuração de Delivery</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Tipo" class="form-label"></label>
                <input asp-for="Tipo" class="form-control" readonly />
            </div>

            @if (Model.Tipo == WebApplication1.Models.TipoDelivery.App)
            {
                <div class="mb-3">
                    <label asp-for="NomeApp" class="form-label">Nome do App</label>
                    <input asp-for="NomeApp" class="form-control" />
                    <span asp-validation-for="NomeApp" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ComissaoPorcentagem" class="form-label">Comissão (%)</label>
                    <input asp-for="ComissaoPorcentagem" class="form-control" type="number" min="0" max="100" />
                </div>
                <div class="mb-3">
                    <label asp-for="TaxaAdicionalApp" class="form-label">Taxa Adicional (R$)</label>
                    <input asp-for="TaxaAdicionalApp" class="form-control" type="number" step="0.01" />
                </div>
            }
            else
            {
                <div class="mb-3">
                    <label asp-for="TaxaFixaProprio" class="form-label">Taxa Fixa de Entrega (R$)</label>
                    <input asp-for="TaxaFixaProprio" class="form-control" type="number" step="0.01" />
                </div>
            }

            <div class="mb-3 form-check">
                <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                <label asp-for="Ativo" class="form-check-label">Ativo</label>
            </div>

            <div class="mt-3">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
