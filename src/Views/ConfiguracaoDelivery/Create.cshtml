@model WebApplication1.Models.ConfiguracaoDelivery
@{
    ViewData["Title"] = "Nova Configuração de Delivery";
    bool jaTemProprio = ViewBag.JaTemProprio ?? false;
}

<h2 class="d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined">local_shipping</span> Nova Configuração de Delivery</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Tipo" class="form-label"></label>
                <select asp-for="Tipo" class="form-select" id="tipoSelect"
                        asp-items="Html.GetEnumSelectList<WebApplication1.Models.TipoDelivery>()">
                </select>
                @if (jaTemProprio)
                {
                    <div class="text-warning small mt-1 d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined" style="font-size:1rem;">warning</span> Já existe um delivery próprio. Você só pode criar do tipo App.</div>
                }
            </div>

            <div id="camposApp">
                <div class="mb-3">
                    <label asp-for="NomeApp" class="form-label">Nome do App</label>
                    <input asp-for="NomeApp" class="form-control" placeholder="ex: iFood, Rappi..." />
                    <span asp-validation-for="NomeApp" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ComissaoPorcentagem" class="form-label">Comissão (%)</label>
                    <input asp-for="ComissaoPorcentagem" class="form-control" type="number" min="0" max="100" />
                    <span asp-validation-for="ComissaoPorcentagem" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="TaxaAdicionalApp" class="form-label">Taxa Adicional (R$)</label>
                    <input asp-for="TaxaAdicionalApp" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="TaxaAdicionalApp" class="text-danger"></span>
                </div>
            </div>

            <div id="camposProprio" style="display:none">
                <div class="mb-3">
                    <label asp-for="TaxaFixaProprio" class="form-label">Taxa Fixa de Entrega (R$)</label>
                    <input asp-for="TaxaFixaProprio" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="TaxaFixaProprio" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                <label asp-for="Ativo" class="form-check-label">Ativo</label>
            </div>

            <div class="mt-3">
                <input type="submit" value="Salvar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const sel = document.getElementById('tipoSelect');
        function toggleCampos() {
            const isApp = sel.value === '0'; // 0=App, 1=Proprio
            document.getElementById('camposApp').style.display = isApp ? '' : 'none';
            document.getElementById('camposProprio').style.display = isApp ? 'none' : '';
        }
        sel.addEventListener('change', toggleCampos);
        toggleCampos();
    </script>
}
