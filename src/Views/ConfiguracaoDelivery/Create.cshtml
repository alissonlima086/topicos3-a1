@model WebApplication1.Models.ConfiguracaoDelivery
@{
    ViewData["Title"] = "Nova Configuração de Delivery";
    bool jaTemProprio = ViewBag.JaTemProprio ?? false;
}

<h2>Nova Configuração de Delivery</h2>

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Tipo" class="form-label"></label>
        <select asp-for="Tipo" class="form-select" id="tipoSelect">
            <option value="App">Delivery App</option>
            @if (jaTemProprio)
            {
                <option value="Proprio" disabled>Delivery Próprio (já cadastrado)</option>
            }
            else
            {
                <option value="Proprio">Delivery Próprio</option>
            }
        </select>
    </div>

    <div id="camposApp">
        <div class="mb-3">
            <label asp-for="NomeApp" class="form-label">Nome do App</label>
            <input asp-for="NomeApp" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ComissaoPorcentagem" class="form-label">Comissão (%)</label>
            <div class="input-group">
                <input asp-for="ComissaoPorcentagem" class="form-control" type="number" min="0" max="100" step="1" placeholder="Ex: 12" />
                <span class="input-group-text">%</span>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="TaxaAdicionalApp" class="form-label">Taxa Adicional por Pedido (R$)</label>
            <div class="input-group">
                <span class="input-group-text">R$</span>
                <input asp-for="TaxaAdicionalApp" class="form-control" type="number" step="0.01" min="0" />
            </div>
        </div>
    </div>

    <div id="camposProprio" style="display:none">
        <div class="mb-3">
            <label asp-for="TaxaFixaProprio" class="form-label">Taxa Fixa por Entrega (R$)</label>
            <div class="input-group">
                <span class="input-group-text">R$</span>
                <input asp-for="TaxaFixaProprio" class="form-control" type="number" step="0.01" min="0" />
            </div>
        </div>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Ativo" class="form-check-input" type="checkbox" checked />
        <label asp-for="Ativo" class="form-check-label">Ativo</label>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <script>
        document.getElementById('tipoSelect').addEventListener('change', function () {
            const isApp = this.value === 'App';
            document.getElementById('camposApp').style.display = isApp ? '' : 'none';
            document.getElementById('camposProprio').style.display = isApp ? 'none' : '';
        });
    </script>
}
