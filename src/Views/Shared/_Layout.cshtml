<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Painel Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-inline-flex align-items-center gap-1" asp-controller="Home" asp-action="Index">
                    <span class="material-symbols-outlined" style="font-size:1.3rem;">restaurant</span> Admin
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">Atendimento</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Atendimento" asp-action="Index">Atendimentos Presenciais</a></li>
                                <li><a class="dropdown-item" asp-controller="Pedido" asp-action="Index">Todos os Pedidos</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">Delivery</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="ConfiguracaoDelivery" asp-action="Index">Configurar Taxas / Apps</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">Cardápio</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Cardapio" asp-action="Index">Cardápios</a></li>
                                <li><a class="dropdown-item" asp-controller="Prato" asp-action="Index">Pratos</a></li>
                                <li><a class="dropdown-item" asp-controller="Ingrediente" asp-action="Index">Ingredientes</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">Salão</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Mesa" asp-action="Index">Mesas</a></li>
                                <li><a class="dropdown-item" asp-controller="Reserva" asp-action="Index">Reservas</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Usuario" asp-action="Index">Usuários</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white d-inline-flex align-items-center gap-1" asp-controller="Relatorio" asp-action="Index">
                                <span class="material-symbols-outlined" style="font-size:1rem;">bar_chart</span>
                                Relatórios
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link nav-link text-white">Sair</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted mt-4 py-2 text-center">
        <small>Painel Administrativo &copy; @DateTime.Now.Year</small>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
