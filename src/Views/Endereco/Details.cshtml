@model WebApplication1.Models.Endereco

@{
    ViewData["Title"] = "Detalhes do Endereço";
}

<h1>Detalhes do Endereço</h1>
<hr />

<dl class="row">
    <dt class="col-sm-2">Local</dt>
    <dd class="col-sm-10">@Model.Local</dd>
    <dt class="col-sm-2">Bairro</dt>
    <dd class="col-sm-10">@Model.Bairro</dd>
    <dt class="col-sm-2">CEP</dt>
    <dd class="col-sm-10">@Model.Cep</dd>
    <dt class="col-sm-2">Complemento</dt>
    <dd class="col-sm-10">@Model.Complemento</dd>
    @if (Model.Usuario != null)
    {
        <dt class="col-sm-2">Usuário</dt>
        <dd class="col-sm-10">@Model.Usuario.Nome</dd>
    }
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Editar</a>
<a asp-action="Index" asp-route-usuarioId="@Model.UsuarioId" class="btn btn-secondary btn-sm ms-2">Voltar</a>
