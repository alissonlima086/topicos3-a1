@model WebApplication1.Models.Endereco

@{
    ViewData["Title"] = "Excluir Endereço";
}

<h1>Excluir Endereço</h1>
<hr />
<div class="alert alert-danger">
    Tem certeza que deseja excluir este endereço?
</div>

<dl class="row">
    <dt class="col-sm-2">Local</dt>
    <dd class="col-sm-10">@Model.Local</dd>
    <dt class="col-sm-2">Bairro</dt>
    <dd class="col-sm-10">@Model.Bairro</dd>
    <dt class="col-sm-2">CEP</dt>
    <dd class="col-sm-10">@Model.Cep</dd>
    <dt class="col-sm-2">Complemento</dt>
    <dd class="col-sm-10">@Model.Complemento</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="usuarioId" value="@Model.UsuarioId" />
    <input type="submit" value="Confirmar Exclusão" class="btn btn-danger" />
    <a asp-action="Index" asp-route-usuarioId="@Model.UsuarioId" class="btn btn-secondary ms-2">Cancelar</a>
</form>
