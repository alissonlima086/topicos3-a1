@model WebApplication1.Models.Reserva

@{
    ViewData["Title"] = "Excluir Reserva";
}

<h1>Excluir Reserva</h1>

<h3>Tem certeza que deseja excluir?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Data)</dt>
        <dd class="col-sm-10">@Model.Data.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.HorarioInicio)</dt>
        <dd class="col-sm-10">@Model.HorarioInicio.ToString("HH:mm")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.HorarioFim)</dt>
        <dd class="col-sm-10">@Model.HorarioFim.ToString("HH:mm")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.NumeroPessoas)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.NumeroPessoas)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Status)</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar</a>
    </form>
</div>
