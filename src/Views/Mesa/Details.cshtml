@model WebApplication1.Models.Mesa

@{
    ViewData["Title"] = "Detalhes da Mesa";
}

<h1>Detalhes da Mesa</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Numero)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Numero)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Capacidade)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Capacidade)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Disponivel)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Disponivel)</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Editar</a> |
    <a asp-action="Index">Voltar</a>
</div>
