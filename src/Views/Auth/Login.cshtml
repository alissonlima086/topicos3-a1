@model WebApplication1.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Senha" class="control-label"></label>
                <input asp-for="Senha" type="password" class="form-control" />
                <span asp-validation-for="Senha" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <input asp-for="LembrarMe" class="form-check-input" />
                <label asp-for="LembrarMe" class="form-check-label"></label>
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Entrar" class="btn btn-primary" />
            </div>
        </form>
        <p class="mt-3">
            Não tem conta? <a asp-action="Cadastro">Cadastre-se</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
