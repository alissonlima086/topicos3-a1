@model WebApplication1.Models.ItemPedido

@{
    ViewData["Title"] = "Remover Item";
}

<h1>Remover Item</h1>

<h3>Tem certeza que deseja remover este item?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.NomePrato)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.NomePrato)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Quantidade)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Quantidade)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.PrecoUnitario)</dt>
        <dd class="col-sm-10">R$ @Model.PrecoUnitario.ToString("F2")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Remover" class="btn btn-danger" /> |
        <a asp-controller="Pedido" asp-action="Details" asp-route-id="@Model.PedidoId">Voltar ao Pedido</a>
    </form>
</div>
