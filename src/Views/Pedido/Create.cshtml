@using WebApplication1.Models
@{
    ViewData["Title"] = "Novo Pedido";
    var cardapio = ViewBag.Cardapio as Cardapio;
    var turno = ViewBag.TurnoAtual as string;
    var configs = ViewBag.Configuracoes as List<WebApplication1.Models.ConfiguracaoDelivery>
        ?? new List<WebApplication1.Models.ConfiguracaoDelivery>();
}

<h2>🛒 Novo Pedido</h2>
<hr />

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form asp-action="Create" method="post" id="formPedido">
    @Html.AntiForgeryToken()

    <div class="row mb-3">
        <div class="col-md-5">
            <label class="form-label fw-bold">ID do Usuário</label>
            <input type="text" name="usuarioId" class="form-control" placeholder="GUID do usuário" required />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-5">
            <label class="form-label fw-bold">Canal de Delivery</label>
            <select name="configuracaoDeliveryId" class="form-select" id="selDelivery" onchange="atualizarTaxa()">
                <option value="" data-taxa="0">Presencial / Sem taxa</option>
                @foreach (var c in configs)
                {
                    var taxa = (c.TaxaFixaProprio ?? c.TaxaAdicionalApp ?? 0).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                    var label = c.Tipo == WebApplication1.Models.TipoDelivery.App ? c.NomeApp : "Delivery Próprio";
                    <option value="@c.Id" data-taxa="@taxa">@label</option>
                }
            </select>
            <div class="form-text text-muted" id="infoTaxa"></div>
        </div>
    </div>

    @if (cardapio == null || !cardapio.Itens.Any())
    {
        <div class="alert alert-warning">
            ⚠️ Nenhum cardápio disponível para o turno <strong>@turno</strong>.
            <a asp-controller="Cardapio" asp-action="Index" class="alert-link">Gerar cardápio</a>
        </div>
    }
    else
    {
        <h5>🍽️ Pratos do Cardápio — <span class="text-muted">@turno</span></h5>
        <p class="text-muted small">⭐ Sugestão do Chef tem 20% de desconto aplicado automaticamente.</p>

        <div class="row g-3 mb-4">
            @{ int idx = 0; }
            @foreach (var item in cardapio.Itens.OrderByDescending(i => i.IsSugestao))
            {
                var precoFinal = item.IsSugestao ? item.Prato!.PrecoBase * 0.8f : item.Prato!.PrecoBase;

                <div class="col-md-4">
                    <div class="card h-100" style="@(item.IsSugestao ? "border:2px solid #f59e0b;" : "")">
                        @if (item.IsSugestao)
                        {
                            <div class="py-1 text-center fw-bold small"
                                 style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white;">
                                ⭐ SUGESTÃO DO CHEF — 20% OFF
                            </div>
                        }
                        <div class="card-body pb-2">
                            <div class="fw-bold">@item.Prato?.Nome</div>
                            @if (item.IsSugestao)
                            {
                                <div>
                                    <span class="text-muted text-decoration-line-through small">R$ @item.Prato!.PrecoBase.ToString("F2")</span>
                                    <span class="text-success fw-bold ms-1">R$ @precoFinal.ToString("F2")</span>
                                </div>
                            }
                            else
                            {
                                <div style="color:#e63946;" class="fw-bold">R$ @precoFinal.ToString("F2")</div>
                            }

                            <input type="hidden" name="itens[@idx].ItemCardapioId" value="@item.Id" />

                            <div class="mt-2 d-flex align-items-center gap-2">
                                <label class="form-label mb-0 small">Qtd:</label>
                                <input type="number" name="itens[@idx].Quantidade"
                                       class="form-control form-control-sm qtd"
                                       data-preco="@precoFinal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                       min="0" value="0" style="width:75px" onchange="recalcular()" />
                            </div>
                            <input type="text" name="itens[@idx].Observacao"
                                   class="form-control form-control-sm mt-2"
                                   placeholder="Observação (opcional)" />
                        </div>
                    </div>
                </div>
                idx++;
            }
        </div>

        <div class="p-3 bg-light rounded mb-4" style="max-width:360px;">
            <div class="d-flex justify-content-between"><span>Subtotal:</span><strong id="subtotal">R$ 0,00</strong></div>
            <div class="d-flex justify-content-between"><span>Taxa de entrega:</span><strong id="taxaDisplay">R$ 0,00</strong></div>
            <hr class="my-1"/>
            <div class="d-flex justify-content-between fs-5"><span>Total:</span><strong id="totalDisplay">R$ 0,00</strong></div>
        </div>

        <button type="submit" class="btn btn-success">Criar Pedido</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
    }
</form>

@section Scripts {
<script>
    let taxaAtual = 0;

    function atualizarTaxa() {
        const sel = document.getElementById('selDelivery');
        taxaAtual = parseFloat(sel.options[sel.selectedIndex].dataset.taxa || '0');
        document.getElementById('infoTaxa').textContent = taxaAtual > 0
            ? 'Taxa: R$ ' + taxaAtual.toFixed(2).replace('.', ',') : '';
        recalcular();
    }

    function recalcular() {
        let sub = 0;
        document.querySelectorAll('.qtd').forEach(el => {
            sub += (parseInt(el.value) || 0) * (parseFloat(el.dataset.preco) || 0);
        });
        const fmt = v => 'R$ ' + v.toFixed(2).replace('.', ',');
        document.getElementById('subtotal').textContent = fmt(sub);
        document.getElementById('taxaDisplay').textContent = fmt(taxaAtual);
        document.getElementById('totalDisplay').textContent = fmt(sub + taxaAtual);
    }
</script>
}
