@model WebApplication1.Models.Pedido

@{
    ViewData["Title"] = "Novo Pedido";
}

<h1>Novo Pedido</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="UsuarioId" class="control-label">Usuário (ID)</label>
                <input asp-for="UsuarioId" class="form-control" />
                <span asp-validation-for="UsuarioId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaxaEntrega" class="control-label"></label>
                <input asp-for="TaxaEntrega" class="form-control" value="0" />
                <span asp-validation-for="TaxaEntrega" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Criar Pedido" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
