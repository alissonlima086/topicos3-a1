@model WebApplication1.Models.Pedido

@{
    ViewData["Title"] = "Excluir Pedido";
}

<h1>Excluir Pedido</h1>

<h3>Tem certeza que deseja excluir?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Data/Hora</dt>
        <dd class="col-sm-10">@Model.DataHora.ToString("dd/MM/yyyy HH:mm")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Status)</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Preço Total</dt>
        <dd class="col-sm-10">R$ @Model.PrecoTotal.ToString("F2")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar</a>
    </form>
</div>
