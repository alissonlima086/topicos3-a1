@model WebApplication1.Models.Pedido

@{
    ViewData["Title"] = "Detalhes do Pedido";
}

<h1>Detalhes do Pedido</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Data/Hora</dt>
        <dd class="col-sm-10">@Model.DataHora.ToString("dd/MM/yyyy HH:mm")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Status)</dt>
        <dd class="col-sm-10"><span class="badge bg-secondary">@Model.Status</span></dd>

        <dt class="col-sm-2">Taxa de Entrega</dt>
        <dd class="col-sm-10">R$ @Model.TaxaEntrega.ToString("F2")</dd>

        <dt class="col-sm-2">Preço Total</dt>
        <dd class="col-sm-10"><strong>R$ @Model.PrecoTotal.ToString("F2")</strong></dd>
    </dl>
</div>

<h4>Itens do Pedido</h4>
<p>
    <a asp-controller="ItemPedido" asp-action="Create" asp-route-pedidoId="@Model.Id" class="btn btn-sm btn-success">Adicionar Item</a>
</p>

@if (Model.Itens != null && Model.Itens.Any())
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Prato</th>
                <th>Qtd</th>
                <th>Preço Unit.</th>
                <th>Subtotal</th>
                <th>Sugestão</th>
                <th>Observação</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Itens)
            {
                <tr>
                    <td>@item.NomePrato</td>
                    <td>@item.Quantidade</td>
                    <td>R$ @item.PrecoUnitario.ToString("F2")</td>
                    <td>R$ @((item.PrecoUnitario * item.Quantidade).ToString("F2"))</td>
                    <td>@(item.FoiSugestao ? "Sim" : "Não")</td>
                    <td>@item.Observacao</td>
                    <td>
                        <a asp-controller="ItemPedido" asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                        <a asp-controller="ItemPedido" asp-action="Delete" asp-route-id="@item.Id">Remover</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Nenhum item adicionado ainda.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id">Editar</a> |
    <a asp-action="Index">Voltar</a>
</div>
