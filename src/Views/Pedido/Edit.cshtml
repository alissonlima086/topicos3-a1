@model WebApplication1.Models.Pedido

@{
    ViewData["Title"] = "Editar Pedido";
}

<h1>Editar Pedido</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UsuarioId" />

            <div class="form-group">
                <label asp-for="DataHora" class="control-label"></label>
                <input asp-for="DataHora" type="datetime-local" class="form-control" />
                <span asp-validation-for="DataHora" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TaxaEntrega" class="control-label"></label>
                <input asp-for="TaxaEntrega" class="form-control" />
                <span asp-validation-for="TaxaEntrega" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PrecoTotal" class="control-label"></label>
                <input asp-for="PrecoTotal" class="form-control" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<WebApplication1.Models.Enums.Status>()" class="form-control"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Salvar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Details" asp-route-id="@Model.Id">Ver Detalhes</a> |
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
