@inherits LayoutComponentBase

<div class="min-vh-100 d-flex flex-column">
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color:#1a1a1a;">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-1" href="/">
                <span class="material-symbols-outlined" style="color:#e63946;">restaurant</span>
                <span style="color:#e63946;">Restaurante</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Cardápio</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/realizar-pedido">
                            <span class="material-symbols-outlined align-middle me-1" style="font-size:1rem;">shopping_cart</span>
                            Fazer Pedido
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/realizar-reserva">
                            <span class="material-symbols-outlined align-middle me-1" style="font-size:1rem;">event_seat</span>
                            Reservar Mesa
                        </NavLink>
                    </li>
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/meus-pedidos">Meus Pedidos</NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/minhas-reservas">Minhas Reservas</NavLink>
                            </li>
                        </Authorized>
                    </AuthorizeView>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                                    <span class="material-symbols-outlined" style="font-size:1.1rem;">person</span>
                                    @context.User.FindFirst("nome")?.Value?.Split(' ')[0]
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="/meu-perfil">Meu Perfil</a></li>
                                    <li><a class="dropdown-item" href="/meus-enderecos">Meus Endereços</a></li>
                                    <li><a class="dropdown-item" href="/alterar-senha">Alterar Senha</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" action="/auth/blazor-logout">
                                            <input name="__RequestVerificationToken" type="hidden" />
                                            <button type="submit" class="dropdown-item text-danger">Sair</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </Authorized>
                        <NotAuthorized>
                            <li class="nav-item">
                                <a class="nav-link" href="/login">Entrar</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-danger btn-sm ms-2" href="/cadastro">Cadastrar</a>
                            </li>
                        </NotAuthorized>
                    </AuthorizeView>
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        @Body
    </main>

    <footer style="background-color:#1a1a1a; color:#aaa;" class="py-3 text-center">
        <small class="d-inline-flex align-items-center gap-1">
            <span class="material-symbols-outlined" style="font-size:1rem;">restaurant</span>
            Restaurante &copy; @DateTime.Now.Year
        </small>
    </footer>
</div>

<div id="blazor-error-ui" class="alert alert-danger m-3" style="display:none;">
    Ocorreu um erro.
    <a href="" class="alert-link">Recarregar</a>
    <a class="float-end" onclick="document.getElementById('blazor-error-ui').style.display='none'">&#x2715;</a>
</div>
