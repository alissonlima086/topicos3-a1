@page "/alterar-senha"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using WebApplication1.Models
@inject UserManager<Usuario> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Alterar Senha</PageTitle>

<div class="container py-5" style="max-width:480px;">
    <h2 class="fw-bold mb-4">Alterar Senha</h2>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert alert-@(erro ? "danger" : "success")">@mensagem</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="mb-3">
                <label class="form-label fw-semibold">Senha atual</label>
                <input type="password" class="form-control" @bind="senhaAtual" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Nova senha</label>
                <input type="password" class="form-control" @bind="novaSenha" />
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Confirmar nova senha</label>
                <input type="password" class="form-control" @bind="confirmarSenha" />
            </div>
            <button class="btn btn-lg w-100 fw-bold text-white" style="background-color:#e63946;"
                    @onclick="Salvar" disabled="@salvando">
                @(salvando ? "Alterando..." : "Alterar Senha")
            </button>
        </div>
    </div>
</div>

@code {
    private Usuario? usuario;
    private string senhaAtual = "", novaSenha = "", confirmarSenha = "";
    private string mensagem = "";
    private bool erro = false, salvando = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        usuario = await UserManager.GetUserAsync(authState.User);
    }

    private async Task Salvar()
    {
        if (usuario == null) return;
        if (novaSenha != confirmarSenha) { mensagem = "As senhas não coincidem."; erro = true; return; }
        if (novaSenha.Length < 6) { mensagem = "Mínimo 6 caracteres."; erro = true; return; }
        salvando = true;
        var result = await UserManager.ChangePasswordAsync(usuario, senhaAtual, novaSenha);
        mensagem = result.Succeeded ? "Senha alterada com sucesso!" : string.Join("; ", result.Errors.Select(e => e.Description));
        erro = !result.Succeeded;
        if (result.Succeeded) senhaAtual = novaSenha = confirmarSenha = "";
        salvando = false;
    }
}
