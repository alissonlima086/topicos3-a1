@page "/meu-perfil"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using WebApplication1.Models
@inject UserManager<Usuario> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Meu Perfil</PageTitle>

<div class="container py-5" style="max-width:540px;">
    <h2 class="fw-bold mb-4">Meu Perfil</h2>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert alert-@(erro ? "danger" : "success")">@mensagem</div>
    }

    @if (usuario != null)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nome</label>
                    <input class="form-control" @bind="nome" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">E-mail</label>
                    <input class="form-control" value="@usuario.Email" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">CPF</label>
                    <input class="form-control" @bind="cpf" />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">Data de Nascimento</label>
                    <input type="date" class="form-control" @bind="dataNascimento" />
                </div>
                <button class="btn btn-lg w-100 fw-bold text-white" style="background-color:#e63946;"
                        @onclick="Salvar" disabled="@salvando">
                    @(salvando ? "Salvando..." : "Salvar")
                </button>
            </div>
        </div>
    }
</div>

@code {
    private Usuario? usuario;
    private string nome = "", cpf = "";
    private DateTime dataNascimento = DateTime.Today;
    private string mensagem = "";
    private bool erro = false, salvando = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        usuario = await UserManager.GetUserAsync(authState.User);
        if (usuario != null)
        {
            nome = usuario.Nome;
            cpf = usuario.Cpf;
            dataNascimento = usuario.DataNascimento;
        }
    }

    private async Task Salvar()
    {
        if (usuario == null) return;
        salvando = true;
        usuario.Nome = nome;
        usuario.Cpf = cpf;
        usuario.DataNascimento = dataNascimento;
        var result = await UserManager.UpdateAsync(usuario);
        mensagem = result.Succeeded ? "Perfil atualizado!" : string.Join("; ", result.Errors.Select(e => e.Description));
        erro = !result.Succeeded;
        salvando = false;
    }
}
